{
  "name": "ai-optimizer",
  "version": "0.0.0",
  "private": true,
  "description": "AI Token Optimizer monorepo root",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "build": "npm run build -w @ai-optimizer/core && npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
